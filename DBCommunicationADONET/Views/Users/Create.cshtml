@model Users

<h1>Add a new user</h1>

<form asp-controller="Users" asp-action="Create" method="post">
	<div class="form-group">
		<lable class="form-lable">Name</lable>
		<input type="text" asp-for="Name" class="form-control"/>
	</div>
	<div class="form-group">
		<lable class="form-lable">Email</lable>
		<input type="text" asp-for="Email" class="form-control"/>
	</div>
	<div class="form-group">
		<lable class="form-lable">Age</lable>
		<input type="text" asp-for="Age" class="form-control" />
	</div>
	<div class="form-group">
		<lable class="form-lable">Date Of Birth</lable>
		<input type="date" asp-for="DateOfBirth" class="form-control" />
	</div>
	<input type="submit" value="Create" class="btn btn-primary mt-3"/>
</form>